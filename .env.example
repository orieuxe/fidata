# Copy to .env and fill in before `docker compose up -d`.

POSTGRES_PASSWORD=change-me

# graphile-migrate (db/), local dev only -- port matches docker-compose.local.yml's
# 5433 host mapping, not docker-compose.yml's internal 5432.
DATABASE_URL=postgres://postgres:change-me@localhost:5433/fidata
SHADOW_DATABASE_URL=postgres://postgres:change-me@localhost:5433/fidata_shadow
ROOT_DATABASE_URL=postgres://postgres:change-me@localhost:5433/postgres

# Public URL PostgREST is reachable at from the browser (same domain,
# proxied under /api by Caddy -- see Caddyfile).
NUXT_PUBLIC_API_BASE=https://your-domain.example/api

# Domain Caddy requests a TLS cert for. Must have an A/AAAA record
# pointing at this server before `docker compose up -d`.
DOMAIN=your-domain.example
