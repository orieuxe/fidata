# Copy to .env and fill in before `docker compose up -d`.

POSTGRES_PASSWORD=change-me

# Public URL PostgREST is reachable at from the browser (same domain,
# proxied under /api by Caddy -- see Caddyfile).
NUXT_PUBLIC_API_BASE=https://your-domain.example/api

# Domain Caddy requests a TLS cert for. Must have an A/AAAA record
# pointing at this server before `docker compose up -d`.
DOMAIN=your-domain.example
